{
    "name": "okvir/webp-safe-migrator",
    "description": "Convert WordPress media to WebP/AVIF/JPEG XL safely, updating all usages and metadata, with validation, rollback and reports.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
