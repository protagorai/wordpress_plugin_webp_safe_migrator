# WebP Safe Migrator - canonical environment for the development app stack.
#
# Copy to ".env" in this directory (setup/docker/) and adjust as needed:
#     cp setup/docker/.env.example setup/docker/.env
#
# docker-compose.yml reads these with sensible defaults, so the WordPress service
# and the MySQL service can never drift apart on credentials again (see review.md
# CRIT-7). The defaults below match the values baked into docker-compose.yml.

# --- Database (shared by the wordpress + db services) ---
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wpuser
WORDPRESS_DB_PASSWORD=wppass
MYSQL_ROOT_PASSWORD=root123

# --- Access notes ---
# The default (SSL) app stack publishes:
#   http://localhost   -> redirects to https
#   https://localhost  -> WordPress (self-signed cert)
#   http://localhost:8081 -> phpMyAdmin
# If you need plain HTTP on :8080 instead, use the native installers
# (setup/quick-install.sh / install-wordpress.sh), which target port 8080.

# --- Integration tests (docker-compose.test.yml) ---
# WordPress version used by the test suite ("latest", "6.5", "trunk", ...).
WP_VERSION=latest
